APP_NAME=Gestao Financeira Empresarial
APP_ENV=local
APP_DEBUG=true

# Preencha antes de subir o Docker Compose.
# Exemplo de formato:
# DATABASE_URL=postgresql+psycopg://app_user:<senha_local>@postgres:5432/app_db
DATABASE_URL=

# Gere um valor forte fora do repositorio.
# Exemplo: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
# Valores aceitos: mock, smtp, brevo_api
EMAIL_DELIVERY_MODE=mock
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Gestao Financeira Empresarial
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=20
BREVO_API_KEY=
BREVO_API_KEY_FILE=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
GOOGLE_CLIENT_ID=

POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=

VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
